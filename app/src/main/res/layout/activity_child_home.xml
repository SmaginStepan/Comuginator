<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvChildHomeTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/ComuginatorText.Title"
        android:text="@string/app_name"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvChildHomeBreadcrumbs"
        style="@style/ComuginatorText.Small"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text=""
        android:maxLines="1"
        android:ellipsize="end"/>

    <Button
        android:id="@+id/btnChildHomeBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/ComuginatorButton"
        android:text="@string/back" />

    <Button
        android:id="@+id/btnChildHomePreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/ComuginatorButton.Secondary"
        android:text="@string/start_preview"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnChildHomeAdd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/ComuginatorButton"
        android:text="@string/add"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChildHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="0dp" />

        <ProgressBar
            android:id="@+id/progressChildHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>