<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvChildHomeTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/ComuginatorText.Title"
        android:text="@string/app_name"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnChildHomeBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/ComuginatorButton"
        android:text="@string/back" />

    <Button
        android:id="@+id/btnChildHomeAdd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/ComuginatorButton"
        android:text="@string/add"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/progressChildHome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChildHome"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1" />

</LinearLayout>