<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvFamily"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/ComuginatorText.Title"
            android:text="@string/family_title_placeholder"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnFamilyAdd"
            android:layout_width="48dp"
            android:layout_height="48dp"
            style="@style/ComuginatorButton"
            android:text="@string/plus" />

        <Button
            android:id="@+id/btnFamilyMore"
            android:layout_width="48dp"
            android:layout_height="48dp"
            style="@style/ComuginatorButton"
            android:text="@string/more" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="0dp">

        <Button
            android:id="@+id/btnLibrary"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/ComuginatorButton.Secondary"
            android:text="@string/library" />

        <Button
            android:id="@+id/btnChildHome"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/ComuginatorButton.Secondary"
            android:text="@string/child_home" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvInvite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        style="@style/ComuginatorText.Small"
        android:text="@string/invite_placeholder"
        android:visibility="gone"/>

    <ImageView
        android:id="@+id/ivInviteQr"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:contentDescription="@string/invite_qr_code"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFamily"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:nestedScrollingEnabled="false" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        style="@style/ComuginatorText.Small"
        android:text="@string/status_placeholder" />


</LinearLayout>