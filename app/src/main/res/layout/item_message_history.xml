<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvCreatedAt"
        style="@style/ComuginatorText.Body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/tvMode"
        style="@style/ComuginatorText.Body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textStyle="bold" />
    <TextView
        android:id="@+id/tvMessageLabel"
        style="@style/ComuginatorText.Body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/message"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessage"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="6dp"
        android:nestedScrollingEnabled="false"  />

    <TextView
        android:id="@+id/tvSuggestedRepliesLabel"
        style="@style/ComuginatorText.Body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/suggested_replies" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSuggestedReplies"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="6dp"
        android:nestedScrollingEnabled="false" />

    <TextView
        android:id="@+id/tvSelectedReplyLabel"
        style="@style/ComuginatorText.Body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/selected_reply" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSelectedReply"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="6dp"
        android:nestedScrollingEnabled="false" />

    <Button
        android:id="@+id/btnRepeat"
        style="@style/ComuginatorButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/repeat" />

</LinearLayout>