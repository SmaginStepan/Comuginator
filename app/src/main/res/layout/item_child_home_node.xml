<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootNode"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="12dp">

    <ImageView
        android:id="@+id/ivNode"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:scaleType="centerCrop"
        android:contentDescription="@null"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNodeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            style="@style/ComuginatorText.Section"
            android:text="@string/item"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:gravity="center"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btnToggleVisibility"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/ComuginatorButton.Secondary"
                android:text="@string/hide" />

            <Button
                android:id="@+id/btnChildMore"
                android:layout_width="48dp"
                android:layout_height="48dp"
                style="@style/ComuginatorButton"
                android:text="@string/more" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>