<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="16dp">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvBreadcrumbs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/ComuginatorText.Small"
            android:text="@string/breadcrumb_library"
            android:maxLines="1"
            android:ellipsize="end" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/ComuginatorButton.Secondary"
            android:text="@string/back" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/ComuginatorText.Title"
        android:text="@string/library"
        android:textSize="24sp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp" />

    <!-- CONTENT -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSets"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- FOOTER -->
    <Button
        android:id="@+id/btnCreateSet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        style="@style/ComuginatorButton"
        android:text="@string/create_set" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="16dp"
        style="@style/ComuginatorText.Small"
        android:gravity="center" />

</LinearLayout>
